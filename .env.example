# TalentLens AI — Environment Variables
# Copy this to .env and fill in values before running locally or deploying.

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
# Set to "production" in prod — disables auto-reload
ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────
# In production, replace * with your actual frontend domain
ALLOWED_ORIGINS=*

# ── SBERT Model ───────────────────────────────────────────────────────────
# Override to use a different sentence-transformers model
SBERT_MODEL=all-MiniLM-L6-v2

# ── Frontend ──────────────────────────────────────────────────────────────
# Set this in your frontend build if deploying static files separately
# VITE_API_BASE_URL=https://api.talentlens.ai/api/v1
# For local dev: http://localhost:8000/api/v1
API_BASE_URL=http://localhost:8000/api/v1
